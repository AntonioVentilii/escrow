{
	"name": "valut-core",
	"version": "0.0.1",
	"scripts": {
		"build": "./scripts/build.sh",
		"test:unit": "scripts/test.unit.sh",
		"test:integration": "scripts/test.integration.sh",
		"test": "npm run test:unit",
		"format": "prettier --write . && ./scripts/format.sh",
		"format:rust": "./scripts/format.rust.sh",
		"lint": "prettier --check . && ./scripts/lint.sh",
		"lint:rust": "./scripts/lint.rust.sh --fix",
		"quality": "npm run format && npm run lint",
		"quality:rust": "npm run format:rust && npm run lint:rust",
		"did": "./scripts/did.sh && npm run format && npm run lint",
		"deploy": "dfx deploy --network local --upgrade-unchanged",
		"deploy:staging": "dfx deploy --network staging --upgrade-unchanged",
		"deploy:prod": "dfx deploy --ic --upgrade-unchanged"
	},
	"devDependencies": {
		"@icp-sdk/bindgen": "^0.2.1",
		"prettier": "^3.8.1",
		"prettier-plugin-motoko": "^0.12.5",
		"prettier-plugin-organize-imports": "^4.3.0"
	}
}
